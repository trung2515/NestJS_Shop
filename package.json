{
  "name": "setting-goal-shopnest",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:dev -w server\" \"npm run dev -w client\"",
    "server": "npm run start:dev -w server",
    "client": "npm run dev -w client",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "style": "npm run format && npm run lint:fix",
    "style:check": "npm run format:check && npm run lint",
    "db:up": "docker compose up -d postgres pgadmin",
    "db:down": "docker compose down",
    "migrate": "npm run migration:run -w server",
    "seed": "npm run seed -w server"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.19.0"
  }
}
